# Configurações do Supabase
SUPABASE_URL=https://seu-projeto-supabase.supabase.co
# Use a chave "service_role" para que o script possa modificar o catálogo e pedidos ignorando RLS
SUPABASE_KEY=sua-chave-service-role-aqui

# Configurações do RadioBOSS HTTP API
# Geralmente o RadioBOSS roda em localhost na porta 9000
RADIOBOSS_API_URL=http://127.0.0.1:9000
RADIOBOSS_PASSWORD=sua-senha-da-api-do-radioboss-se-houver

# Pastas no SSD para varredura de músicas (use caminhos absolutos e separe por vírgula)
# Aceita tanto arquivos MP3 quanto MP4 (áudio e vídeo)
MUSIC_DIRECTORIES=D:\Musicas,D:\Videos

# Configurações do Worker
# Tempo de espera em segundos entre cada checagem de novos pedidos no mural
LOOP_INTERVAL_SECONDS=5

# Configurações de Voz Neural (Microsoft Edge-TTS)
# Vozes recomendadas para pt-BR: pt-BR-AntonioNeural (Masculino) ou pt-BR-FranciscaNeural (Feminino)
TTS_VOICE=pt-BR-AntonioNeural
# Taxa de velocidade da fala (valores negativos diminuem o ritmo deixando mais natural, ex: -8%, -5%, +0%)
TTS_RATE=-8%

